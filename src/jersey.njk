---
layout: base.njk
title: "Jersey"
description: "The story of BWW's jersey — 'Be Safe, Be Smart, Be Seen' — and the photos members have sent back from around the world."
permalink: /jersey/
---
<section class="hero" style="min-height:64vh;">
  <img class="hero-img" src="{{ jersey.hero_image }}" alt="BWW members wearing the club's yellow jerseys, from the 'Murder of Crows' photo.">
  <div class="hero-content">
    <span class="hero-tag">{{ jersey.hero_tag }}</span>
    <h1>{{ jersey.hero_heading }}</h1>
    <p class="lede">{{ jersey.hero_text }}</p>
  </div>
</section>

<section class="section-paper">
  <div class="container split">
    <div>
      <span class="eyebrow">The story</span>
      <h2>{{ jersey.story_heading }}</h2>
      {% for p in jersey.story_paragraphs %}<p>{{ p }}</p>{% endfor %}
      <a class="btn btn-dark" href="/contact/">Contact the Secretary</a>
    </div>
    <div>
      <img src="{{ jersey.story_image }}" alt="Detail of the BWW jersey design." style="border-radius:4px;">
    </div>
  </div>
</section>

<section class="section-tight">
  <div class="container">
    <span class="eyebrow">Where in the World</span>
    <h2>{{ jersey.gallery_heading }}</h2>
    <p class="lede">{{ jersey.gallery_intro }}</p>
    <div class="gallery" style="margin-top:2em;">
      {% for g in jersey.gallery %}
      {% if loop.index <= 4 %}
      <figure><img src="{{ g.image }}" alt="{{ g.alt }}"><figcaption>{{ g.caption }}</figcaption></figure>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section-paper">
  <div class="container">
    <div class="gallery" style="margin-top:0;">
      {% for g in jersey.gallery %}
      {% if loop.index > 4 %}
      <figure><img src="{{ g.image }}" alt="{{ g.alt }}"><figcaption>{{ g.caption }}</figcaption></figure>
      {% endif %}
      {% endfor %}
    </div>
    <p style="margin-top:1.6em;">{{ jersey.eras_note }}</p>
  </div>
</section>

<section class="section-dark">
  <div class="container">
    <div class="callout" style="background:var(--bitumen-soft); border:1px solid rgba(242,195,24,0.25);">
      <div>
        <span class="eyebrow" style="color:var(--hivis)">Own a piece of it</span>
        <h3>{{ jersey.callout_heading }}</h3>
        <p>{{ jersey.callout_text }}</p>
      </div>
      <a class="btn btn-primary" href="/contact/">Get in touch</a>
    </div>
  </div>
</section>
